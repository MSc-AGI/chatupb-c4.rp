    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 200;
  }
  // Element,Person
  .Element-RWxlbWVudCxQZXJzb24= {
    BackgroundColor: #e85d04;
    LineColor: #a24102;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #ffffff;
