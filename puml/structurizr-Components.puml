person "==Contacto\n<size:15>[Person]</size>\n\nOtro usuario de ChatUPB en la misma red" <<Element-RWxlbWVudCxQZXJzb24=>> as Contacto

rectangle "ChatUPB\n<size:16>[Software System]</size>" <<Boundary-Q2hhdFVQQg==>> {
  rectangle "ChatUPB App\n<size:16>[Container: Java 21 / Swing]</size>" <<Boundary-Q2hhdFVQQiBBcHA=>> {
    rectangle "==SocketClient\n<size:16>[Component: Java Socket]</size>\n\nConexion de socket hacia un peer. Envia y recibe mensajes serializados" <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as ChatUPB.ChatUPBApp.SocketClient
    rectangle "==SocketListener\n<size:16>[Component: Java Interface]</size>\n\nInterfaz de callback para eventos de red (mensaje recibido, desconexion)" <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as ChatUPB.ChatUPBApp.SocketListener
    rectangle "==ConnectionDB\n<size:16>[Component: Java Class]</size>\n\nSingleton. Gestiona la conexion JDBC a SQLite. Crea tablas si no existen" <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as ChatUPB.ChatUPBApp.ConnectionDB
    rectangle "==ContactDao\n<size:16>[Component: Java DAO]</size>\n\nAcceso a datos de contactos (CRUD, busqueda por IP, lista negra)" <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as ChatUPB.ChatUPBApp.ContactDao
    rectangle "==CacheContactDao\n<size:16>[Component: Java Class]</size>\n\nCache en memoria de contactos para acceso rapido" <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as ChatUPB.ChatUPBApp.CacheContactDao
    rectangle "==ChatsDao\n<size:16>[Component: Java DAO]</size>\n\nAcceso a datos de conversaciones y mensajes" <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as ChatUPB.ChatUPBApp.ChatsDao
    rectangle "==ListaNegraDao\n<size:16>[Component: Java DAO]</size>\n\nAcceso a datos de contactos bloqueados" <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as ChatUPB.ChatUPBApp.ListaNegraDao
    rectangle "==DaoHelper\n<size:16>[Component: Java Class]</size>\n\nUtilidad generica para ejecutar queries y procedimientos SQL" <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as ChatUPB.ChatUPBApp.DaoHelper
    rectangle "==ChatUI\n<size:16>[Component: Java Swing JFrame]</size>\n\nVentana principal. Lista de contactos, panel de chat, envio de mensajes" <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as ChatUPB.ChatUPBApp.ChatUI
    rectangle "==ChatUIStyles\n<size:16>[Component: Java Class]</size>\n\nEstilos visuales, colores, fuentes y bordes personalizados" <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as ChatUPB.ChatUPBApp.ChatUIStyles
    rectangle "==ThemeManager\n<size:16>[Component: Java Enum/Class]</size>\n\nGestiona temas visuales (claro/oscuro) con paleta de colores" <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as ChatUPB.ChatUPBApp.ThemeManager
    rectangle "==ContactRenderer\n<size:16>[Component: Java ListCellRenderer]</size>\n\nRenderizador personalizado para la lista de contactos (avatar, notificaciones)" <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as ChatUPB.ChatUPBApp.ContactRenderer
    rectangle "==Message / Mensaje\n<size:16>[Component: Java POJOs (Lombok)]</size>\n\nEntidades de mensajes: Hello, Aceptar, Rechazar, Invitacion, Zumbido, CambiarTema, FijarMensaje, EliminarMensaje, MensajeUnico, etc." <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as ChatUPB.ChatUPBApp.MessageMensaje
    rectangle "==ChatUPB_V2\n<size:16>[Component: Java Main Class]</size>\n\nPunto de entrada. Inicializa la aplicacion y el look-and-feel del sistema" <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as ChatUPB.ChatUPBApp.ChatUPB_V2
    rectangle "==Mediador\n<size:16>[Component: Java Class]</size>\n\nControlador central (patron Mediator). Coordina red, vista y persistencia. Singleton." <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as ChatUPB.ChatUPBApp.Mediador
    rectangle "==ChatsController\n<size:16>[Component: Java Class]</size>\n\nGestiona operaciones CRUD de conversaciones" <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as ChatUPB.ChatUPBApp.ChatsController
    rectangle "==ContactController\n<size:16>[Component: Java Class]</size>\n\nGestiona operaciones CRUD de contactos" <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as ChatUPB.ChatUPBApp.ContactController
    rectangle "==ChatServer\n<size:16>[Component: Java ServerSocket]</size>\n\nServerSocket que escucha conexiones entrantes de otros usuarios" <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as ChatUPB.ChatUPBApp.ChatServer
  }

  database "==SQLite Database\n<size:16>[Container: SQLite 3.45]</size>\n\nBase de datos local en ~/Library/Application Support/ChatUPB/chat_upb.sqlite" <<Element-RWxlbWVudCxEYXRhYmFzZQ==>> as ChatUPB.SQLiteDatabase
}

ChatUPB.ChatUPBApp.ChatUPB_V2 --> ChatUPB.ChatUPBApp.Mediador <<Relationship-UmVsYXRpb25zaGlw>> : "Inicializa"
ChatUPB.ChatUPBApp.ChatUPB_V2 --> ChatUPB.ChatUPBApp.ChatUI <<Relationship-UmVsYXRpb25zaGlw>> : "Crea y muestra"
ChatUPB.ChatUPBApp.Mediador --> ChatUPB.ChatUPBApp.ChatServer <<Relationship-UmVsYXRpb25zaGlw>> : "Inicia servidor de escucha"
ChatUPB.ChatUPBApp.Mediador --> ChatUPB.ChatUPBApp.SocketClient <<Relationship-UmVsYXRpb25zaGlw>> : "Crea conexiones salientes a peers"
ChatUPB.ChatUPBApp.Mediador --> ChatUPB.ChatUPBApp.ChatsController <<Relationship-UmVsYXRpb25zaGlw>> : "Delega operaciones de chat"
ChatUPB.ChatUPBApp.Mediador --> ChatUPB.ChatUPBApp.ContactController <<Relationship-UmVsYXRpb25zaGlw>> : "Delega operaciones de contacto"
ChatUPB.ChatUPBApp.Mediador --> ChatUPB.ChatUPBApp.ChatUI <<Relationship-UmVsYXRpb25zaGlw>> : "Actualiza la vista con nuevos mensajes/eventos"
ChatUPB.ChatUPBApp.ChatsController --> ChatUPB.ChatUPBApp.ChatsDao <<Relationship-UmVsYXRpb25zaGlw>> : "CRUD de conversaciones"
ChatUPB.ChatUPBApp.ContactController --> ChatUPB.ChatUPBApp.ContactDao <<Relationship-UmVsYXRpb25zaGlw>> : "CRUD de contactos"
ChatUPB.ChatUPBApp.ContactController --> ChatUPB.ChatUPBApp.CacheContactDao <<Relationship-UmVsYXRpb25zaGlw>> : "Consulta cache"
ChatUPB.ChatUPBApp.ContactController --> ChatUPB.ChatUPBApp.ListaNegraDao <<Relationship-UmVsYXRpb25zaGlw>> : "Consulta lista negra"
ChatUPB.ChatUPBApp.ContactDao --> ChatUPB.ChatUPBApp.DaoHelper <<Relationship-UmVsYXRpb25zaGlw>> : "Ejecuta queries"
ChatUPB.ChatUPBApp.ChatsDao --> ChatUPB.ChatUPBApp.DaoHelper <<Relationship-UmVsYXRpb25zaGlw>> : "Ejecuta queries"
ChatUPB.ChatUPBApp.ListaNegraDao --> ChatUPB.ChatUPBApp.DaoHelper <<Relationship-UmVsYXRpb25zaGlw>> : "Ejecuta queries"
ChatUPB.ChatUPBApp.DaoHelper --> ChatUPB.ChatUPBApp.ConnectionDB <<Relationship-UmVsYXRpb25zaGlw>> : "Obtiene conexion JDBC"
ChatUPB.ChatUPBApp.ConnectionDB --> ChatUPB.SQLiteDatabase <<Relationship-UmVsYXRpb25zaGlw>> : "JDBC a SQLite"
ChatUPB.ChatUPBApp.ChatServer --> ChatUPB.ChatUPBApp.SocketClient <<Relationship-UmVsYXRpb25zaGlw>> : "Acepta conexion entrante, crea SocketClient"
ChatUPB.ChatUPBApp.SocketClient --> ChatUPB.ChatUPBApp.Mediador <<Relationship-UmVsYXRpb25zaGlw>> : "Notifica mensajes recibidos via SocketListener"
ChatUPB.ChatUPBApp.SocketClient --> ChatUPB.ChatUPBApp.MessageMensaje <<Relationship-UmVsYXRpb25zaGlw>> : "Serializa/deserializa mensajes"
ChatUPB.ChatUPBApp.ChatUI --> ChatUPB.ChatUPBApp.Mediador <<Relationship-UmVsYXRpb25zaGlw>> : "Envia acciones del usuario (enviar mensaje, agregar contacto)"
ChatUPB.ChatUPBApp.ChatUI --> ChatUPB.ChatUPBApp.ChatUIStyles <<Relationship-UmVsYXRpb25zaGlw>> : "Aplica estilos"
ChatUPB.ChatUPBApp.ChatUI --> ChatUPB.ChatUPBApp.ThemeManager <<Relationship-UmVsYXRpb25zaGlw>> : "Obtiene tema activo"
ChatUPB.ChatUPBApp.ChatUI --> ChatUPB.ChatUPBApp.ContactRenderer <<Relationship-UmVsYXRpb25zaGlw>> : "Renderiza lista de contactos"
ChatUPB.ChatUPBApp.SocketClient --> Contacto <<Relationship-UmVsYXRpb25zaGlw>> : "Conexion TCP directa (socket sin cifrar)"

@enduml